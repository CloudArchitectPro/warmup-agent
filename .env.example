# ─── Brevo SMTP ───────────────────────────────────────────────────────────────
BREVO_SMTP_HOST=smtp-relay.brevo.com
BREVO_SMTP_PORT=587
BREVO_SMTP_LOGIN=your_brevo_login@example.com
BREVO_SMTP_KEY=your_brevo_smtp_api_key

# ─── Anthropic Claude API ─────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── SQLite DB path (defaults to ./data/warmup.db if not set) ────────────────
# DB_PATH=/home/pi/warmup-agent/data/warmup.db

# ─── IMAP passwords (one per domain in your config.json domainRing) ──────────
# Naming convention: IMAP_PASSWORD_<DOMAIN_SLUG>
# Slug: replace dots and hyphens with underscores, uppercase
# Examples:
#   yourdomain1.com  → IMAP_PASSWORD_YOURDOMAIN1_COM
#   my-domain.org   → IMAP_PASSWORD_MY_DOMAIN_ORG

IMAP_PASSWORD_YOURDOMAIN1_COM=
IMAP_PASSWORD_YOURDOMAIN2_COM=
IMAP_PASSWORD_YOURDOMAIN3_COM=
IMAP_PASSWORD_YOURDOMAIN4_COM=
IMAP_PASSWORD_YOURDOMAIN5_COM=

# ─── Optional: IMAP user override per domain ─────────────────────────────────
# If blank, the first sender address for that domain is used as IMAP login.
# IMAP_USER_YOURDOMAIN1_COM=admin@yourdomain1.com
